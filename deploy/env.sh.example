# Source this from your shell OR copy to /etc/vision-mcp/env.sh.
# /etc/vision-mcp/env.sh must be mode 0640 and owned by root:ubuntu — readable
# by the supervisor-launched ubuntu process but not by world. install.sh sets
# these permissions automatically.

export ARK_BASE_URL="https://ark.cn-beijing.volces.com"
export ARK_API_KEY="REPLACE_ME"
export ARK_MODEL="doubao-seed-2-0-mini-260215"
export VISION_BEARER_TOKEN="REPLACE_ME_WITH_64_HEX_CHARS"
export HOST="127.0.0.1"
export PORT="8100"